# 1. Ignore WordPress Core (These cause 90% of conflicts)
/wp-admin/
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
!/wp-config-sample.php

# 2. Ignore System & IDE files (Major source of local conflicts)
.DS_Store
.vscode/
.idea/
*.log
Thumbs.db

# 3. Ignore Huge/Temporary Folders
/wp-content/upgrade/
/wp-content/cache/
/wp-content/uploads/

# 4. TRACK PLUGINS AND THEMES (Keep these)
# We ignore the folder first, then "un-ignore" the parts we want
/wp-content/*
!/wp-content/plugins/
!/wp-content/themes/
!/wp-content/languages/

# 5. Security (Never push your actual config)
wp-config.php
.htaccess